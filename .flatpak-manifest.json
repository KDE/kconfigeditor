{
    "id": "org.kde.configeditor",
    "branch": "master",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "rename-icon": "configure",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_NET_OFFLINE": "true",
            "RUSTFLAGS": "--remap-path-prefix =../"
        }
    },
    "command": "configeditor",
    "tags": [
        "nightly"
    ],
    "desktop-file-name-suffix": " (Nightly)",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=host",
        "--filesystem=/var:ro",
        "--filesystem=~/.var/app/",
        "--filesystem=xdg-data/flatpak:ro",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.kde.kwalletd5",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--talk-name=org.freedesktop.secrets",
        "--talk-name=org.kde.kuiserver",
        "--own-name=org.kde.StatusNotifierItem-2-2"
    ],
    "cleanup": [
        "/include",
        "/lib/*.a",
        "/lib/cmake",
        "/lib/pkgconfig",
        "/share/ndk-modules"
    ],
    "modules": [
        {
            "name": "corrosion",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/corrosion-rs/corrosion",
                    "tag": "v0.6.0"
                }
            ]
        },
        {
            "name": "fuse",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/libfuse/libfuse",
                    "branch": "master"
                }
            ],
            "config-opts": [
                "-Dinitscriptdir=/app/etc/init.d",
                "-Dexamples=false",
                "-Duseroot=false"
            ]
        },
        {
            "name": "ostree",
            "buildsystem": "autotools",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/ostreedev/ostree",
                    "branch": "main"
                }
            ],
            "config-opts": [
                "--disable-man",
                "--with-curl",
                "--without-libsystemd"
            ]
        },
        {
            "name": "libflatpak",
            "buildsystem": "meson",
            "config-opts": [
                "-Dgtkdoc=disabled",
                "-Ddocbook_docs=disabled",
                "-Dtests=false",
                "-Dman=disabled",
                "-Dseccomp=disabled",
                "-Dselinux_module=disabled",
                "-Dmalcontent=disabled",
                "-Dsandboxed_triggers=false",
                "-Dsystemd=disabled",
                "-Dsystem_helper=disabled",
                "-Dsystem_bubblewrap=bwrap",
                "-Dsystem_dbus_proxy=xdg-dbus-proxy",
                "-Dsystem_install_dir=/var/lib/flatpak",
                "-Dsystem_fusermount=fusermount3"
            ],
            "modules": [
                ".flatpak/pyparsing.yaml"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flatpak/flatpak/",
                    "tag": "1.17.7"
                },
                {
                    "type": "patch",
                    "path": ".flatpak/0001-Patch-out-running-brwap-during-the-build.patch"
                }
            ]
        },
        {
            "name": "kconfigeditor",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF"
            ],
            "build-options": {
                "env": {
                    "CARGO_HOME": "/run/build/kconfigeditor/cargo"
                }
            },
            "sources": [
                ".flatpak/generated-sources.json",
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
